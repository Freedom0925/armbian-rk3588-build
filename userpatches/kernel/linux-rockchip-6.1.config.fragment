# 核心：Android 基础（必须第一个开） 
CONFIG_ANDROID=y 
CONFIG_ANDROID_BINDER_IPC=y 
CONFIG_ANDROID_BINDERFS=y 
CONFIG_ANDROID_BINDERFS_USER=y 
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder,anbox-binder,anbox-hwbinder,anbox-vndbinder" 
# Binder 强制依赖：匿名共享内存（必开！） 
CONFIG_ASHMEM=y 
CONFIG_ASHMEM_USER=y 
# RK3588 vendor 内核必需 
CONFIG_TRUSTY=y 
CONFIG_TRUSTY_ANDROID=y
